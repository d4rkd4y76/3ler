        ".validate": "(!newData.exists()) || newData.isBoolean()"
      },
      "libraryName": {
        ".validate": "(!newData.exists()) || (newData.isString() && newData.val().length <= 128)"
      },
      "libraryId": {
        ".validate": "(!newData.exists()) || (newData.isString() && newData.val().length <= 32)"
      },
      "videoId": {
