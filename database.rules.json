            ".validate": "(!newData.exists()) || (newData.isString() && newData.val().length <= 800)"
          },
          "narrationAudioUrl": {
            ".validate": "(!newData.exists()) || (newData.isString() && newData.val().length <= 800)"
          },
          "updatedAt": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          }
        }
      },
      "letters": {
        "$letter": {
          "audioUrl": {
            ".validate": "(!newData.exists()) || (newData.isString() && newData.val().length <= 800)"
          },
          "updatedAt": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          }
        }
      },
      "updatedAt": {
        ".validate": "(!newData.exists()) || newData.isNumber()"
      }
    },
    "roboroxLearn": {
      ".read": true,
      ".write": true,
      "lessons": {
        ".read": true,
        ".write": true,
