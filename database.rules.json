{
  "rules": {
    "admin": {
      ".read": true,
      ".write": true
    },
    "adminPanelUsers": {
      "$classId": {
        "$studentId": {
          ".read": true,
          ".write": true
        }
      }
    },
    "classes": {
      ".read": true,
      ".write": true,
      "$classId": {
        "students": {
          ".indexOn": [
            "inDuel",
            "online",
            "name",
            "nameLower"
          ],
          "$studentId": {
            "inDuel": {
              ".read": true,
              ".write": true
            },
            "diamond": {
              ".read": true,
              ".write": true,
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 25000"
            },
            "lastDiamondUpdate": {
              ".read": true,
              ".write": true,
              ".validate": "newData.isNumber()"
            },
            "gameCup": {
              ".read": true,
              ".write": true,
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "duelCredits": {
              ".read": true,
              ".write": true,
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "unlimitedCreditsUntil": {
              ".read": true,
              ".write": true,
              ".validate": "newData.isNumber() || newData.val() == null"
            },
            "frameX": {
              ".read": true,
              ".write": true,
              ".validate": "newData.isBoolean()"
            },
            "championPhoto": {
              ".read": true,
              ".write": true,
              ".validate": "newData.hasChildren()"
            },
            "photo": {
              ".read": true,
              ".write": true
            },
            "purchasedPhotos": {
              ".read": true,
              ".write": true
            },
            "battleHero": {
              ".read": true,
              ".write": true,
              ".validate": "newData.isString()"
            },
            "purchasedBattleHeroes": {
              ".read": true,
              ".write": true,
              "$heroId": {
                ".validate": "newData.val() === true || (newData.hasChildren() && newData.child('level').isNumber() && newData.child('level').val() >= 1 && newData.child('level').val() <= 4)"
              }
            }
          }
        }
      }
    },
    "championData": {
      ".read": true,
      ".write": true,
      "headings": {
        "$headingId": {
          "lessons": {
            "$lessonId": {
              "topics": {
                "$topicId": {
                  "videoUrl": {
                    ".validate": "(!newData.exists()) || (newData.isString() && (newData.val() == '' || newData.val().matches(/^https:\\/\\/(www\\.)?youtube\\.com\\/embed\\/.+/) || newData.val().matches(/^https:\\/\\/youtube\\.com\\/embed\\/.+/)))"
                  }
                }
              }
            }
          }
        }
      }
    },
    "lessonVideoLookup": {
      ".read": true,
      ".write": true,
      "$lessonName": {
        "$topicName": {
          ".validate": "(!newData.exists()) || (newData.isString() && (newData.val() == '' || newData.val().matches(/^https:\\/\\/(www\\.)?youtube\\.com\\/embed\\/.+/) || newData.val().matches(/^https:\\/\\/youtube\\.com\\/embed\\/.+/)))"
        }
      }
    },
    "invitations": {
      ".read": true,
      ".write": true,
      ".indexOn": [
        "timestamp",
        "invitedId",
        "invitedByStudentId"
      ],
      "$invitedId": {
        ".validate": "newData.hasChildren(['invitedByStudentId', 'timestamp']) || !newData.exists()"
      }
    },
    "rejectedInvites": {
      ".read": true,
      ".write": true,
      ".indexOn": [
        "inviterId",
        "invitedId",
        "timestamp"
      ],
      "$inviteId": {
        ".validate": "(!newData.exists()) || (newData.hasChildren(['inviterId','invitedId','timestamp']))",
        "timestamp": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "duels": {
      ".read": true,
      ".write": true,
      ".indexOn": [
        "inviter/studentId",
        "invited/studentId",
        "inviterId",
        "invitedId",
        "timestamp"
      ],
      "$duelId": {
        "inviter": {
          ".read": true,
          ".write": true
        },
        "invited": {
          ".read": true,
          ".write": true
        },
        "responses": {
          ".indexOn": [
            "timestamp"
          ],
          "$responseId": {
            "timestamp": {
              ".validate": "(!newData.exists()) || newData.isNumber()"
            }
          }
        }
      }
    },
    "seasonRanking": {
      ".read": true,
      ".write": false,
      "topPlayers": {
        ".read": true,
        ".write": false
      },
      "meta": {
        ".read": true,
        ".write": false
      }
    },
    "loggedinPlayers": {
      ".read": true,
      ".write": true,
      ".indexOn": [
        "studentId",
        "classId",
        "online",
        "inDuel"
      ]
    },
    "friendships": {
      ".read": true,
      ".write": true,
      "$userId": {
        ".indexOn": [
          "createdAt"
        ],
        "$friendshipId": {
          "createdAt": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          }
        }
      }
    },
    "matchmaking": {
      ".read": true,
      ".write": true,
      "$classId": {
        ".indexOn": [
          "timestamp",
          "status"
        ]
      }
    },
    "autoMatchCoordinator": {
      ".read": true,
      ".write": true,
      "$classId": {
        ".read": true,
        ".write": true
      }
    },
    "duelQueue": {
      ".read": true,
      ".write": true,
      "twoPlayer": {
        ".indexOn": [
          "timestamp",
          "status",
          "classStatus"
        ],
        "$entryId": {
          ".validate": "newData.hasChildren(['studentId','classId','status','timestamp','classStatus'])",
          "status": {
            ".validate": "newData.val() == 'waiting' || newData.val() == 'claimed' || newData.val() == 'started' || newData.val() == 'cancelled'"
          },
          "classStatus": {
            ".validate": "newData.val() == (newData.parent().child('classId').val() + '_' + newData.parent().child('status').val())"
          },
          "timestamp": {
            ".validate": "newData.isNumber()"
          }
        }
      },
      "fourPlayer": {
        ".indexOn": [
          "timestamp",
          "status"
        ],
        "$entryId": {
          ".validate": "newData.hasChildren(['studentIds','classId','status','timestamp'])",
          "status": {
            ".validate": "newData.val() == 'waiting' || newData.val() == 'claimed' || newData.val() == 'started' || newData.val() == 'cancelled'"
          },
          "timestamp": {
            ".validate": "newData.isNumber()"
          }
        }
      }
    },
    "store": {
      ".read": true,
      ".write": true,
      "categoryMeta": {
        "$categoryKey": {
          ".validate": "newData.hasChildren(['label']) && newData.child('label').isString()",
          "label": {
            ".validate": "newData.isString()"
          },
          "order": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          },
          "createdAt": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          }
        }
      },
      "profilePhotos": {
        ".read": true,
        ".write": true,
        "$category": {
          "_meta": {
            "keep": {
              ".validate": "newData.isBoolean()"
            }
          },
          "$photoId": {
            ".validate": "newData.hasChildren(['url','price']) && newData.child('url').isString() && newData.child('price').isNumber() && (!newData.child('name').exists() || newData.child('name').isString()) && (!newData.child('allowedStudents').exists() || newData.child('allowedStudents').hasChildren())"
          }
        }
      },
      "nameFrames": {
        ".read": true,
        ".write": true,
        "$frameId": {
          ".validate": "newData.hasChildren(['name','price']) && newData.child('name').isString() && newData.child('price').isNumber()"
        }
      },
      "battleHeroLevelConfig": {
        ".read": true,
        ".write": true
      },
      "battleHeroes": {
        ".read": true,
        ".write": true,
        "$heroId": {
          ".validate": "newData.hasChildren(['name','price']) && newData.child('name').isString() && newData.child('price').isNumber()"
        }
      },
      "profilePhotosIndex": {
        ".read": true,
        ".write": true
      }
    },
    "analytics": {
      ".read": true,
      ".write": true,
      "sessions": {
        "$studentId": {
          ".indexOn": [
            "startedAt"
          ],
          "$sessionId": {
            ".validate": "newData.hasChildren(['startedAt'])",
            "startedAt": {
              ".validate": "newData.isNumber()"
            },
            "endedAt": {
              ".validate": "(!newData.exists()) || newData.isNumber()"
            },
            "durationMs": {
              ".validate": "(!newData.exists()) || newData.isNumber()"
            },
            "userAgent": {
              ".validate": "(!newData.exists()) || newData.isString()"
            }
          }
        }
      },
      "duels": {
        "$studentId": {
          ".validate": "newData.hasChildren()",
          "played": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          },
          "wins": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          },
          "losses": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          },
          "last": {
            ".validate": "(!newData.exists()) || newData.hasChildren(['at'])",
            "at": {
              ".validate": "newData.isNumber()"
            },
            "winner": {
              ".validate": "(!newData.exists()) || newData.isString()"
            },
            "loser": {
              ".validate": "(!newData.exists()) || newData.isString()"
            }
          }
        }
      },
      "topicPerf": {
        "$studentId": {
          ".indexOn": [
            "at"
          ],
          "$entryId": {
            ".validate": "newData.hasChildren(['at','topic','total','wrong'])",
            "at": {
              ".validate": "newData.isNumber()"
            },
            "topic": {
              ".validate": "newData.isString()"
            },
            "total": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "wrong": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            }
          }
        }
      }
    },
    "errors": {
      "$studentId": {
        "$topicKey": {
          "wrong": {
            ".validate": "newData.isNumber()"
          }
        }
      }
    },
    "topicPerf": {
      "$studentId": {
        ".indexOn": [
          "at"
        ],
        "$entryId": {
          ".validate": "newData.hasChildren(['at','topic','total','wrong'])",
          "at": {
            ".validate": "newData.isNumber()"
          },
          "topic": {
            ".validate": "newData.isString()"
          },
          "total": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "wrong": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        }
      }
    },
    "homeworks": {
      ".read": true,
      ".write": true,
      ".indexOn": [
        "createdAt",
        "status"
      ],
      "$hwId": {
        "title": {
          ".validate": "newData.isString()"
        },
        "description": {
          ".validate": "(!newData.exists()) || newData.isString()"
        },
        "questionCount": {
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 100"
        },
        "headingId": {
          ".validate": "newData.isString()"
        },
        "lessonId": {
          ".validate": "newData.isString()"
        },
        "topicId": {
          ".validate": "newData.isString()"
        },
        "questionIds": {
          "$idx": {
            ".validate": "newData.isString()"
          }
        },
        "videoOverride": {
          ".validate": "(!newData.exists()) || (newData.isString() && (newData.val() == '' || newData.val().matches(/^https:\\/\\/(www\\.)?youtube\\.com\\/embed\\/.+/) || newData.val().matches(/^https:\\/\\/youtube\\.com\\/embed\\/.+/)))"
        },
        "assignees": {
          ".validate": "newData.hasChildren()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "createdBy": {
          ".validate": "(!newData.exists()) || newData.isString()"
        },
        "status": {
          ".validate": "newData.val() == 'active' || newData.val() == 'archived'"
        }
      }
    },
    "studentHomework": {
      ".read": true,
      ".write": true,
      "$studentId": {
        ".indexOn": [
          "status"
        ],
        "$hwId": {
          ".validate": "(!newData.exists()) || (newData.hasChildren(['status','assignedAt']))",
          "status": {
            ".validate": "newData.val()=='assigned'||newData.val()=='completed'||newData.val()=='cancelled'"
          },
          "assignedAt": {
            ".validate": "newData.isNumber()"
          },
          "completedAt": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          },
          "correct": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          },
          "total": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          }
        }
      }
    },
    "studentHomeworkSummary": {
      "$studentId": {
        "pendingCount": {
          ".read": true,
          ".write": true,
          ".validate": "(!newData.exists()) || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000)"
        }
      }
    },
    "classesIndex": {
      ".read": true,
      ".write": true,
      "$classId": {
        ".validate": "(!newData.exists()) || newData.isString() || (newData.hasChildren(['name']) && newData.child('name').isString())"
      }
    },
    "topicVideoUrls": {
      ".read": true,
      ".write": true,
      "$topicId": {
        ".read": true,
        ".write": true,
        ".validate": "(!newData.exists()) || newData.isString()"
      }
    },
    "homeworkResults": {
      ".read": true,
      ".write": true,
      "$hwId": {
        "$studentId": {
          ".validate": "(!newData.exists()) || (newData.hasChildren(['correct','total','startedAt','finishedAt']))",
          "correct": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "total": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "startedAt": {
            ".validate": "newData.isNumber()"
          },
          "finishedAt": {
            ".validate": "newData.isNumber()"
          },
          "durationMs": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          }
        }
      }
    },
    "weeklyMissions": {
      ".read": true,
      ".write": true,
      "$studentId": {
        ".validate": "(!newData.exists()) || (newData.hasChildren(['weekId','progress']) && newData.child('weekId').isString())",
        "weekId": {
          ".validate": "newData.isString()"
        },
        "progress": {
          ".validate": "newData.hasChildren()",
          "$missionId": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
          }
        },
        "claimed": {
          ".validate": "(!newData.exists()) || newData.hasChildren()",
          "$missionId": {
            ".validate": "newData.isNumber()"
          }
        },
        "updatedAt": {
          ".validate": "(!newData.exists()) || newData.isNumber()"
        }
      }
    },
    "denemeMeta": {
      ".read": true,
      ".write": true,
      "enabled": {
        ".validate": "(!newData.exists()) || newData.isBoolean()"
      },
      "ended": {
        ".validate": "(!newData.exists()) || newData.isBoolean()"
      },
      "lastResetAt": {
        ".validate": "(!newData.exists()) || newData.isNumber()"
      }
    },
    "denemeQuestions": {
      ".read": true,
      ".write": true,
      "$qid": {
        ".validate": "(!newData.exists()) || (newData.hasChildren(['question','correct','wrong1','wrong2','wrong3']) && newData.child('correct').isString() && newData.child('wrong1').isString() && newData.child('wrong2').isString() && newData.child('wrong3').isString() && newData.child('question').exists())"
      }
    },
    "denemeAttempts": {
      ".read": true,
      ".write": true,
      ".indexOn": [
        "finishedAt"
      ],
      "$attemptId": {
        ".validate": "(!newData.exists()) || (newData.hasChildren(['studentId','startedAt','finishedAt','durationMs','correctCount','wrongCount','total','bySubject']) && newData.child('studentId').isString() && newData.child('startedAt').isNumber() && newData.child('finishedAt').isNumber() && newData.child('durationMs').isNumber() && newData.child('correctCount').isNumber() && newData.child('correctCount').val() >= 0 && newData.child('wrongCount').isNumber() && newData.child('wrongCount').val() >= 0 && newData.child('total').isNumber() && newData.child('total').val() >= 0 && newData.child('bySubject').exists())",
        "awayCount": {
          ".validate": "(!newData.exists()) || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 3)"
        },
        "answers": {
          ".validate": "(!newData.exists()) || newData.hasChildren()",
          "$idx": {
            ".validate": "newData.hasChildren(['question','chosen','correct','isCorrect'])",
            "question": {
              ".validate": "newData.isString()"
            },
            "chosen": {
              ".validate": "newData.isString()"
            },
            "correct": {
              ".validate": "newData.isString()"
            },
            "isCorrect": {
              ".validate": "newData.isBoolean()"
            }
          }
        }
      }
    },
    "denemeResults": {
      ".read": true,
      ".write": true,
      "$studentId": {
        "$attemptId": {
          ".validate": "(!newData.exists()) || (newData.hasChildren(['studentId','startedAt','finishedAt','durationMs','correctCount','wrongCount','total','bySubject']) && newData.child('studentId').isString() && newData.child('studentId').val() == $studentId && newData.child('startedAt').isNumber() && newData.child('finishedAt').isNumber() && newData.child('durationMs').isNumber() && newData.child('correctCount').isNumber() && newData.child('correctCount').val() >= 0 && newData.child('wrongCount').isNumber() && newData.child('wrongCount').val() >= 0 && newData.child('total').isNumber() && newData.child('total').val() >= 0 && newData.child('bySubject').exists())",
          "awayCount": {
            ".validate": "(!newData.exists()) || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 3)"
          },
          "answers": {
            ".validate": "(!newData.exists()) || newData.hasChildren()",
            "$idx": {
              ".validate": "newData.hasChildren(['question','chosen','correct','isCorrect'])",
              "question": {
                ".validate": "newData.isString()"
              },
              "chosen": {
                ".validate": "newData.isString()"
              },
              "correct": {
                ".validate": "newData.isString()"
              },
              "isCorrect": {
                ".validate": "newData.isBoolean()"
              }
            }
          }
        }
      }
    },
    "denemeProgress": {
      ".read": true,
      ".write": true,
      "$studentId": {
        ".validate": "(!newData.exists()) || (newData.hasChildren(['studentId','startedAt','index','score','wrong','awayCount','bySubject','questions','updatedAt']) && newData.child('studentId').isString() && newData.child('studentId').val() == $studentId && newData.child('startedAt').isNumber() && newData.child('index').isNumber() && newData.child('index').val() >= 0 && newData.child('score').isNumber() && newData.child('score').val() >= 0 && newData.child('wrong').isNumber() && newData.child('wrong').val() >= 0 && newData.child('awayCount').isNumber() && newData.child('awayCount').val() >= 0 && newData.child('awayCount').val() <= 3 && newData.child('questions').hasChildren() && newData.child('updatedAt').isNumber())",
        "answers": {
          ".validate": "(!newData.exists()) || newData.hasChildren()",
          "$idx": {
            ".validate": "newData.hasChildren(['question','chosen','correct','isCorrect'])",
            "question": {
              ".validate": "newData.isString()"
            },
            "chosen": {
              ".validate": "newData.isString()"
            },
            "correct": {
              ".validate": "newData.isString()"
            },
            "isCorrect": {
              ".validate": "newData.isBoolean()"
            }
          }
        }
      }
    },
    "denemeLeaderboard": {
      ".read": true,
      ".write": true,
      ".indexOn": [
        "bestCorrect",
        "finishedAt"
      ],
      "$studentId": {
        ".validate": "(!newData.exists()) || (newData.hasChildren(['studentId','bestCorrect','bestDurationMs']) && newData.child('studentId').isString() && newData.child('studentId').val() == $studentId && newData.child('bestCorrect').isNumber() && newData.child('bestCorrect').val() >= 0 && newData.child('bestDurationMs').isNumber() && newData.child('bestDurationMs').val() >= 0)"
      }
    },
    "denemeAgg": {
      ".read": true,
      ".write": true,
      "subjects": {
        "$subject": {
          "correct": {
            ".validate": "(!newData.exists()) || (newData.isNumber() && newData.val() >= 0)"
          },
          "wrong": {
            ".validate": "(!newData.exists()) || (newData.isNumber() && newData.val() >= 0)"
          },
          "updatedAt": {
            ".validate": "(!newData.exists()) || newData.isNumber()"
          }
        }
      }
    },
    "fillBlanks": {
      ".read": true,
      ".write": true,
      "questions": {
        "$qid": {
          ".validate": "(!newData.exists()) || (newData.hasChildren(['text','answer']) && newData.child('text').isString() && newData.child('answer').isString())"
        }
      },
      "questionIds": {
        "$qid": {
          ".validate": "(!newData.exists()) || newData.isBoolean()"
        }
      },
      "attempts": {
        "$studentId": {
          "$dayKey": {
            ".validate": "(!newData.exists()) || (newData.hasChildren(['questionId','answer','correct','at']) && newData.child('questionId').isString() && newData.child('answer').isString() && newData.child('correct').isBoolean() && newData.child('at').isNumber())"
          }
        }
      }
    },
    "dailyPuzzles": {
      ".read": true,
      ".write": true,
      "questions": {
        "$qid": {
          ".validate": "(!newData.exists()) || (newData.hasChildren(['word']) && newData.child('word').isString() && newData.child('word').val().length >= 2 && newData.child('word').val().length <= 40)"
        }
      },
      "questionIds": {
        "$qid": {
          ".validate": "(!newData.exists()) || newData.isBoolean()"
        }
      }
    },
    "dailyPuzzle": {
      ".read": true,
      ".write": true,
      "attempts": {
        "$studentId": {
          "$dayKey": {
            ".validate": "(!newData.exists()) || (newData.hasChildren(['guess','correct','at']) && newData.child('guess').isString() && newData.child('correct').isBoolean() && newData.child('at').isNumber())"
          }
        }
      }
    },
    "matchingGame": {
      ".read": true,
      ".write": true,
      "questions": {
        "$qid": {
          ".validate": "(!newData.exists()) || (newData.hasChildren(['left','right','pairs']) && newData.child('left').hasChildren() && newData.child('right').hasChildren() && newData.child('pairs').hasChildren())"
        }
      },
      "questionIds": {
        "$qid": {
          ".validate": "(!newData.exists()) || newData.isBoolean()"
        }
      },
      "attempts": {
        "$studentId": {
          "$dayKey": {
            ".validate": "(!newData.exists()) || (newData.hasChildren(['questionId','picks','at']) && newData.child('questionId').isString() && newData.child('picks').hasChildren() && newData.child('at').isNumber())"
          }
        }
      }
    },
    "appDuyuru": {
      ".read": true,
      ".write": true,
      "text": {
